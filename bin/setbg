#!/bin/env fish

function rand
	test ! -d $argv && return 1
	ls "$argv"/*.{png,jpg,jpeg,webp} 2>/dev/null | shuf -n 1
end

if test -z "$argv"
	set wall $(rand ~/Pictures/Wallpapers)
else if test -d "$argv"
	set wall $(rand $argv)
else if test -f "$argv"
	set wall "$argv"
end

test ! -f "$wall" && echo "error: invalid input" && exit 1

set portrait false
test $(identify -format "%[fx:w/h]" "$wall") -lt 1 && set portrait true

# set the wallpaper
if string match -qi "*gnome*" "$XDG_CURRENT_DESKTOP"
	if "$portrait"
		gsettings set org.gnome.desktop.background picture-options 'scaled'
		gsettings set org.gnome.desktop.background primary-color '#000000'
	else
		gsettings set org.gnome.desktop.background picture-options 'zoom'
	end
	gsettings set org.gnome.desktop.background picture-uri "$wall"
	gsettings set org.gnome.desktop.background picture-uri-dark "$wall"
else if test -n "$WAYLAND_DISPLAY"
	set old $(pidof swaybg)
	if "$portrait"
		nohup swaybg -c "#000000" -m "fit" -i "$wall" &>/dev/null &
	else
		nohup swaybg -m "fill" -i "$wall" &>/dev/null &
	end
	test -n "$old" && kill "$old"
else
	if "$portrait"
		feh --bg-max "$wall"
	else
		feh --bg-fill "$wall"
	end
end
